{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "rootDir": ".",
    "paths": {
      "@splatvault/shared-types": ["./packages/shared-types/src"],
      "@splatvault/embedding": ["./packages/embedding/src"],
      "@splatvault/indexer": ["./packages/indexer/src"]
    }
  },
  "exclude": ["node_modules", "dist", "build"]
}
